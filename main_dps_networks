    "#Jacobian\n",
    "def Jac(x,L):\n",
    "    return np.block([[np.zeros((N,N)),np.identity(N)],[-L,-2*np.diag(x)]])\n",
    "\n",
    "#Lyapunov exponent of the Jacobian with heterogeneous damping\n",
    "def LE(x,L,num_zeros):\n",
    "    J=Jac(x,L)\n",
    "    EV=np.real(np.sort(LA.eigvals(J)))\n",
    "    return EV[len(EV)-1-num_zeros]\n",
    "\n",
    "#Lyapunov exponent of the Jacobian with homogeneous damping\n",
    "def LE_hom(x,L,num_zeros):\n",
    "    J=Jac(x*np.ones(N),L)\n",
    "    EV=np.real(np.sort(LA.eigvals(J)))\n",
    "    return EV[len(EV)-1-num_zeros]\n",
    "\n",
    "#Calculate the average eigenvalue when noise is imputed \n",
    "def calculate_dist(eps,rand_vec,min_hom_x,L,num_zeros):\n",
    "    return LE(eps*rand_vec+min_hom_x,L,num_zeros)\n",
    "\n",
    "#Calculate the optimal homogeneous damping\n",
    "def calc_hom_damp(L,num_zeros):\n",
    "    n_iter=10**(7)\n",
    "    p0=[1]\n",
    "    result_min = minimize(LE_hom,x0=p0, method='Nelder-Mead',args=(L,num_zeros), options={'maxiter':n_iter})\n",
    "    min_hom_fun=result_min.fun\n",
    "    min_hom_x=result_min.x\n",
    "    return min_hom_fun, min_hom_x\n",
    "\n",
    "#Create the Laplacian given the adjacency matrix\n",
    "def L_from_A(A):\n",
    "    L=np.zeros((N,N))\n",
    "    for i in range (N):\n",
    "        for j in range (N):\n",
    "            L[i][j]=-A[i][j]\n",
    "    for i in range (N):\n",
    "        L[i][i]=sum(A[i])\n",
    "    return L\n",
    "\n",
    "#Create a circulant adjacency matrix with only first neighbors interaction. The weights of the interactions are taken with uniform probability\n",
    "#between [0,1], and its sum is taken to be 1.\n",
    "def create_A_circulant_ass(N):\n",
    "    delta=np.random.rand(1)\n",
    "    vec=np.zeros(N)\n",
    "    vec[1]=delta\n",
    "    vec[N-1]=1-delta\n",
    "    return circulant(vec)\n",
    "\n",
    "#Create adjacency matrix for SF network\n",
    "def create_A_SF_ass(N,m):\n",
    "    G=nx.barabasi_albert_graph(N, m)\n",
    "    A=nx.to_numpy_array(G)\n",
    "    for i in range (N):\n",
    "        for j in range (i+1,N):\n",
    "            A[i][j]*=np.random.rand(1)\n",
    "    return A\n",
    "\n",
    "#Create an asymmetric adjacency matrix with SW distribution and weight with uniform distribution\n",
    "def create_A_SW_ass(N,k,p):\n",
    "    G=nx.watts_strogatz_graph(N, k, 0)\n",
    "    A=nx.to_numpy_array(G)\n",
    "    for i in range (N):\n",
    "        for j in range (N):\n",
    "            if (((abs(j-i)%N-k//2<=0) or (N-abs(j-i)%N-k//2<=0)) and (i!=j))==True:\n",
    "                if p>np.random.rand(1):\n",
    "                    A[i][j]=0\n",
    "                    already_filled=np.nonzero(A[i])[0]\n",
    "                    vec_exc=[i,j]\n",
    "                    for l in range (len(already_filled)):\n",
    "                        vec_exc.append(already_filled[l])\n",
    "                    if len(vec_exc)<N-1:\n",
    "                        l=random.choice([m for m in range(0,N-1) if m not in vec_exc])\n",
    "                        A[i][l]=np.random.rand(1)\n",
    "    return A"
   ]
