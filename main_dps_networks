   "source": [
    "N=20 #size of the matrix\n",
    "N_lap=5 #number of different Laplacians\n",
    "N_het=5 #number of different noises\n",
    "N_eps=5 #number of different noise magnitudes being considered \n",
    "\n",
    "m=5 #number of edges that are being attached to every new node in the modified scale-free network\n",
    "p=0.25 #probability of every edge to be reconnected in the modified small network model\n",
    "num_zeros=1 #number of trivial zeros of the Jacobian matrix, for artificial networks it is 1\n",
    "\n",
    "het_vec=np.zeros((N_het,N))\n",
    "L_vec=np.zeros((N_lap,N,N))\n",
    "eps_vec=np.linspace(0,1,N_eps)\n",
    "\n",
    "#Create the different random Laplacians. This step is only done for the artificial networks\n",
    "for i in range (N_lap):\n",
    "    A=create_A_SF_ass(N,m)\n",
    "    #A=create_A_SW_ass(N,k,p)\n",
    "    L=L_from_A(A)\n",
    "    L_vec[i]=L\n",
    "\n",
    "#create vectors with uniform probability between [-0.5,0.5]\n",
    "for i in range (N_het):\n",
    "    rand_vec=np.random.rand(N)-0.5\n",
    "    het_vec[i]=rand_vec\n",
    "\n",
    "\n",
    "diff_vec=np.zeros((N_lap,N_eps))\n",
    "f_desc=np.zeros((N_lap,N_eps))\n",
    "\n",
    "for j in range (N_lap):#iterate over the different laplacians\n",
    "    L=L_vec[j]\n",
    "    min_hom_fun, min_hom_x=calc_hom_damp(L,num_zeros)\n",
    "    for k in range (N_eps):#iterate over the different magnitude of noises\n",
    "        eps=eps_vec[k]\n",
    "        diff_vec_aux=np.zeros(N_het)\n",
    "        for i in range (N_het):#iterate over the different noises\n",
    "            rand_vec=het_vec[i]\n",
    "            dist=calculate_dist(min_hom_x*eps,rand_vec,min_hom_x,L,num_zeros)\n",
    "            diff_vec_aux[i]=(dist-min_hom_fun)/abs(min_hom_fun)\n",
    "\n",
    "        negative_count = np.sum(diff_vec_aux < 0)\n",
    "\n",
    "        f_desc[j][k]=negative_count/N_het#calculate fraction of noises that lead to an improvement in the Lyapunov exponent\n",
    "        diff_vec[j][k]=min(diff_vec_aux)#calculate the best improvement \n"
   ]
  }
